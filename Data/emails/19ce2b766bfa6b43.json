-size:10px;\">&nbsp;</div>\r\n      <img src=\"https://image.com.ethias.be/lib/fe3d117075640475761670/m/1/9caec790-8f16-4c8b-901f-b8067adbd4d2.png\" width=\"12\" height=\"11\" style=\"display:block;border:0;\">\r\n    </td>\r\n    <td valign=\"top\" width=\"90%\" style=\"padding:3px; font-family:'Fira Sans', Arial, Helvetica, sans-serif; font-size:18px; line-height:26px; color:#000;\">\r\n     <b>Door je tijdig te waarschuwen</b> <br>Is er een beter tarief? Dan krijg je een seintje.\r\n    </td>\r\n  </tr>\r\n\r\n  <tr>\r\n   <td valign=\"top\" width=\"10%\" align=\"center\">\r\n      <!-- Spacer -->\r\n      <div style=\"height:10px; line-height:10px; font-size:10px;\">&nbsp;</div>\r\n      <img src=\"https://image.com.ethias.be/lib/fe3d117075640475761670/m/1/9caec790-8f16-4c8b-901f-b8067adbd4d2.png\" width=\"12\" height=\"11\" style=\"display:block;border:0;\">\r\n    </td>\r\n    <td valign=\"top\" width=\"90%\" style=\"padding:3px; font-family:'Fira Sans', Arial, Helvetica, sans-serif; font-size:18px; line-height:26px; color:#000;\">\r\n     <b>Door de overstap te regelen</b> <br>Zonder extra kosten. Zonder administratie voor jou.\r\n    </td>\r\n  </tr>\r\n\r\n  <tr>\r\n   <td valign=\"top\" width=\"10%\" align=\"center\">\r\n      <!-- Spacer -->\r\n      <div style=\"height:10px; line-height:10px; font-size:10px;\">&nbsp;</div>\r\n      <img src=\"https://image.com.ethias.be/lib/fe3d117075640475761670/m/1/9caec790-8f16-4c8b-901f-b8067adbd4d2.png\" width=\"12\" height=\"11\" style=\"display:block;border:0;\">\r\n    </td>\r\n    <td valign=\"top\" width=\"90%\" style=\"padding:3px; font-family:'Fira Sans', Arial, Helvetica, sans-serif; font-size:18px; line-height:26px; color:#000;\">\r\n      <b>Jij behoudt het overzicht</b> <br>Met realtime inzicht in je verbruik en kosten via het June-platform. \r\n    </td>\r\n  </tr>\r\n</table>\r\n</td></tr></table></td></tr></table></td></tr></table></td></tr></table><table cellpadding=\"0\" cellspacing=\"0\" width=\"100