dding-top: 0;\">\n        \n      <table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" width=\"100%\">\n        <tbody>\n          <tr>\n            <td style=\"vertical-align:top;padding:auto;\">\n              \n      <table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style width=\"100%\">\n        <tbody>\n          \n              <tr>\n                <td align=\"left\" vertical-align=\"middle\" style=\"font-size:0px;padding:auto;word-break:break-word;\">\n                  \n      <table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"border-collapse:separate;line-height:100%;\">\n        <tbody>\n          <tr>\n            <td align=\"center\" bgcolor=\"transparent\" role=\"presentation\" style=\"border:none;border-radius:3px;cursor:auto;mso-padding-alt:10px 25px;background:transparent;\" valign=\"middle\">\n              <a href=\"https://www.revolut.com/app/payments/new-transfer?tracking_id=8093b998-38c2-3e80-baf6-999001951635\" style=\"display: inline-block; background: transparent; margin: 0; text-transform: none; mso-padding-alt: 0px; line-height: 1.375; text-decoration: none; font-family: Inter, -apple-system, Roboto, 'Segoe UI', Arial, sans-serif; font-weight: 500; border-radius: 68px; padding: 10px 16px; font-size: 14px; background-color: #FFFFFF; color: #000000;\" target=\"_blank\" >\n                Отправить международный перевод              </a>\n            </td>\n          </tr>\n        </tbody>\n      </table>\n    \n                </td>\n              </tr>\n            \n        </tbody>\n      </table>\n    \n            </td>\n          </tr>\n        </tbody>\n      </table>\n    \n      </div>\n    \n          <!--[if mso | IE]></td><![endif]-->\n    \n      <!--[if mso | IE]></tr></table><![endif]-->\n              </td>\n            </tr>\n          </tbody>\n        </table>\n        \n      </div>\n    \n      \n      <!--[if mso | IE]></td></tr></t