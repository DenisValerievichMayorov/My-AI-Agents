div style=\"background:#FFFFFF;background-color:#FFFFFF;margin:0px auto;max-width:700px;\"><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"background:#FFFFFF;background-color:#FFFFFF;width:100%;\"><tbody><tr><td style=\"direction:ltr;font-size:0px;padding:0;text-align:center;\"><!--[if mso | IE]><table role=\"presentation\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\"><tr><td class=\"\" style=\"vertical-align:top;width:700px;\" ><![endif]--><div class=\"mj-column-per-100 mj-outlook-group-fix\" style=\"font-size:0px;text-align:left;direction:ltr;display:inline-block;vertical-align:top;width:100%;\"><table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" width=\"100%\"><tbody><tr><td style=\"vertical-align:top;padding:0;\"><table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" width=\"100%\"><tbody><tr><td align=\"center\" class=\"rev-title-eBDUE-8-Ez\" style=\"font-size:0px;padding:16px 24px;word-break:break-word;\"><div style=\"font-family:Aeonik Pro, Inter, Arial, sans-serif;font-size:34px;font-style:normal;font-weight:900;letter-spacing:-0.2px;line-height:119%;text-align:center;color:#1A1C1F;\">Get your documents ready for tax season</div></td></tr></tbody></table></td></tr></tbody></table></div><!--[if mso | IE]></td></tr></table><![endif]--></td></tr></tbody></table></div><!--[if mso | IE]></td></tr></table></td></tr><tr><td align=\"left\" class=\"\" width=\"700px\" ><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" class=\"\" role=\"presentation\" style=\"width:700px;\" width=\"700\" bgcolor=\"#FFFFFF\" ><tr><td style=\"line-height:0px;font-size:0px;mso-line-height-rule:exactly;\"><![endif]--><div style=\"background:#FFFFFF;background-color:#FFFFFF;margin:0px auto;max-width:700px;\"><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"background:#FFFFFF;background-color:#FFFFFF;width:100%;\"><tbody><tr><td style=\"direction:ltr;font-size:0px;padding:0;text-align:center;\"><!--[if mso | IE]><table role=\"presentation\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\"><tr><td class=\"\" style=\"vertical-align:top;width:700px;\" ><![endif]--><div class=\"mj-column-per-100 mj-outlook-group-fix\" style=\"font-size:0px;text-align:left;direction:ltr;display:inline-block;vertical-align:top;width:100%;\"><table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" width=\"100%\"><tbody><tr><td style=\"vertical-align:top;padding:0;\"><table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" width=\"100%\"><tbody><tr><td align=\"left\" class=\"rev-text-4HCE2Ue58x\" style=\"font-size:0px;padding:0;word-break:break-word;\"><div style=\"font-family:Inter, Arial, sans-serif;font-size:16px;font-style:normal;font-weight:400;line-height:130%;text-align:left;color:#1A1C1F;\"><p style=\"margin: 16px 0;\">Hi Denys,</p><p style=\"margin: 16px 0;\">The tax declaration deadline for the year 2025 in Belgium is 30 June.</p><p style=\"margin: 16px 0;\">You can get most documents and statements needed for your tax return easily through the Revolut app. Read on to find out how.</p></div></td></tr></tbody></table></td></tr></tbody></table></div><!--[if mso | IE]></td></tr></table><![endif]--></td></tr></tbody></table></div><!--[if mso | IE]></td></tr></table></td></tr><tr><td align=\"left\" class=\"\" width=\"700px\" ><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" class=\"\" role=\"presentation\" style=\"width:700px;\" width=\"700\" bgcolor=\"#FFFFFF\" ><tr><td style=\"line-height:0px;font-size:0px;mso-line-height-rule:exactly;\"><![endif]--><div style=\"background:#FFFFFF;background-color:#FFFFFF;margin:0px auto;max-width:700px;\"><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"background:#FFFFFF;background-color:#FFFFFF;width:100%;\"><tbody><tr><td style=\"direction:ltr;font-size:0px;padding:0;text-align:center;\"><!--[if mso | IE]><table role=\"presentation\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\"><tr><td class=\"\" style=\"vertical-align:top;width:700px;\" ><![endif]--><div class=\"mj-column-per-100 mj-outlook-group-fix\" style=\"font-size:0px;text-align:left;direction:ltr;display:inline-block;vertical-align:top;width:100%;\"><table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" width=\"100%\"><tbody><tr><td style=\"vertical-align:top;padding:0;\"><table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" width=\"100%\"><tbody><tr><td align=\"left\" class=\"rev-text-C2MgBBO-6a\" style=\"font-size:0px;padding:0;word-break:break-word;\"><div style=\"font-family:Inter, Arial, sans-serif;font-size:16px;font-style:normal;font-weight:400;line-height:130%;text-align:left;color:#1A1C1F;\"><h3 style=\"font-weight: 700; line-height: 119%; margin: 0; padding: 0; font-size: 20px; padding-top: 16px;\">Download your custom statement</h3><p style=\"margin: 16px 0;\">You can generate and download your custom statement in the Revolut app. This document can then be easily shared or submitted when you file your taxes.</p><p style=\"margin: 16px 0;\">To download your custom statement:</p><ul style=\"margin: 16px 0 16px 24px; padding: 0;\"><li style=\"margin: 4px 0; padding: 0;\">Tap your profile icon in the top-left corner</li><li style=\"margin: 4px 0; padding: 0;\">Select <strong>Documents &amp; Statements</strong></li><li style=\"margin: 4px 0; padding: 0;\">Tap <strong>Custom statement</strong></li><li style=\"margin: 4px 0; padding: 0;\">Tap <strong>Customise</strong> to choose accounts, transaction, currency and language</li><li style=\"margin: 4px 0; padding: 0;\">Select the time range and click <strong>Generate</strong></li></ul></div></td></tr></tbody></table></td></tr></tbody></table></div><!--[if mso | IE]></td></tr></table><![endif]--></td></tr></tbody></table></div><!--[if mso | IE]></td></tr></table></td></tr><tr><td align=\"left\" class=\"\" width=\"700px\" ><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" class=\"\" role=\"presentation\" style=\"width:700px;\" width=\"700\" bgcolor=\"#FFFFFF\" ><tr><td style=\"line-height:0px;font-size:0px;mso-line-height-rule:exactly;\"><![endif]--><div style=\"background:#FFFFFF;background-color:#FFFFFF;margin:0px auto;max-width:700px;\"><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"background:#FFFFFF;background-color:#FFFFFF;width:100%;\"><tbody><tr><td style=\"direction:ltr;font-size:0px;padding:0;text-align:center;\"><!--[if mso | IE]><table role=\"presentation\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\"><tr><td class=\"\" style=\"vertical-align:top;width:700px;\" ><![endif]--><div class=\"mj-column-per-100 mj-outlook-group-fix\" style=\"font-size:0px;text-align:left;direction:ltr;display:inline-block;vertical-align:top;width:100%;\"><table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" width=\"100%\"><tbody><tr><td style=\"vertical-align:top;padding:0;\"><table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" width=\"100%\"><tbody><tr><td align=\"left\" class=\"rev-text-gfQlbdA5Mh\" style=\"font-size:0px;padding:0;word-break:break-word;\"><div style=\"font-family:Inter, Arial, sans-serif;font-size:16px;font-style:normal;font-weight:400;line-height:130%;text-align:left;color:#1A1C1F;\"><h3 style=\"font-weight: 700; line-height: 119%; margin: 0; padding: 0; font-size: 20px; padding-top: 16px;\">What details are in my custom statement?</h3><p style=\"margin: 16px 0;\">The custom statement contains most of the information needed when filing your taxes, including:</p><ul style=\"margin: 16px 0 16px 24px; padding: 0;\"><li style=\"margin: 4px 0; padding: 0;\"><strong>Summarised report</strong> of earned interest, capital gains and other proceeds</li><li style=\"margin: 4px 0; padding: 0;\"><strong>Details of the products you use and your accounts with us, </strong>including account numbers and the countries where your assets are held</li><li style=\"margin: 4px 0; padding: 0;\"><strong>Customisable details</strong> by account, time period, transaction types, and currency</li></ul></div></td></tr></tbody></table></td></tr></tbody></table></div><!--[if mso | IE]></td></tr></table><![endif]--></td></tr></tbody></table></div><!--[if mso | IE]></td></tr></table></td></tr><tr><td align=\"left\" class=\"\" width=\"700px\" ><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" class=\"\" role=\"presentation\" style=\"width:700px;\" width=\"700\" bgcolor=\"#FFFFFF\" ><tr><td style=\"line-height:0px;font-size:0px;mso-line-height-rule:exactly;\"><![endif]--><div style=\"background:#FFFFFF;background-color:#FFFFFF;margin:0px auto;max-width:700px;\"><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"background:#FFFFFF;background-color:#FFFFFF;width:100%;\"><tbody><tr><td style=\"direction:ltr;font-size:0px;padding:0;text-align:center;\"><!--[if mso | IE]><table role=\"presentation\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\"><tr><td class=\"\" style=\"vertical-align:top;width:700px;\" ><![endif]--><div class=\"mj-column-per-100 mj-outlook-group-fix\" style=\"font-size:0px;text-align:left;direction:ltr;display:inline-block;vertical-align:top;width:100%;\"><table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" width=\"100%\"><tbody><tr><td style=\"vertical-align:top;padding:0;\"><table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" width=\"100%\"><tbody><tr><td align=\"left\" class=\"rev-text-aeu22VUPvj\" style=\"font-size:0px;padding:0;word-break:break-word;\"><div style=\"font-family:Inter, Arial, sans-serif;font-size:16px;font-style:normal;font-weight:400;line-height:130%;text-align:left;color:#1A1C1F;\"><h3 style=\"font-weight: 700; line-height: 119%; margin: 0; padding: 0; font-size: 20px; padding-top: 16px;\">Can Revolut file my taxes?</h3><p style=\"margin: 16px 0;\">We can&#39;t file your taxes on your behalf. Any profits you earn through our products may be subject to taxation in accordance with local tax laws.</p></div></td></tr></tbody></table></td></tr></tbody></table></div><!--[if mso | IE]></td></tr></table><![endif]--></td></tr></tbody></table></div><!--[if mso | IE]></td></tr></table></td></tr><tr><td align=\"left\" class=\"\" width=\"700px\" ><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" class=\"\" role=\"presentation\" style=\"width:700px;\" width=\"700\" bgcolor=\"#FFFFFF\" ><tr><td style=\"line-height:0px;font-size:0px;mso-line-height-rule:exactly;\"><![endif]--><div style=\"background:#FFFFFF;background-color:#FFFFFF;margin:0px auto;max-width:700px;\"><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"background:#FFFFFF;background-color:#FFFFFF;width:100%;\"><tbody><tr><td style=\"direction:ltr;font-size:0px;padding:0;text-align:center;\"><!--[if mso | IE]><table role=\"presentation\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\"><tr><td class=\"\" style=\"vertical-align:top;width:700px;\" ><![endif]--><div class=\"mj-column-per-100 mj-outlook-group-fix\" style=\"font-size:0px;text-align:left;direction:ltr;display:inline-block;vertical-align:top;width:100%;\"><table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" width=\"100%\"><tbody><tr><td style=\"vertical-align:top;padding:0;\"><table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" width=\"100%\"><tbody><tr><td align=\"left\" class=\"rev-text-b0rDiSTUzG\" style=\"font-size:0px;padding:0;word-break:break-word;\"><div style=\"font-family:Inter, Arial, sans-serif;font-size:16px;font-style:normal;font-weight:400;line-height:130%;text-align:left;color:#1A1C1F;\"><h3 style=\"font-weight: 700; line-height: 119%; margin: 0; padding: 0; font-size: 20px; padding-top: 16px;\">Does Revolut offer tax advice?</h3><p style=\"margin: 16px 0;\">We can&#39;t offer tax advice. For professional tax advice, you&#39;ll need to reach out to a certified tax advisor.</p><p style=\"margin: 16px 0;\">It&#39;s your responsibility to understand how you must declare taxes and make respective tax payments. We aren&#39;t responsible or liable for any of your tax or related charges, fees, costs or penalties you have to pay.</p><p style=\"margin: 16px 0;\">Always check the national tax authority website for the latest information on tax deadlines, your tax liability, and the process for filing taxes.</p></div></td></tr></tbody></table></td></tr></tbody></table></div><!--[if mso | IE]></td></tr></table><![endif]--></td></tr></tbody></table></div><!--[if mso | IE]></td></tr></table></td></tr><tr><td align=\"left\" class=\"\" width=\"700px\" ><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" class=\"\" role=\"presentation\" style=\"width:700px;\" width=\"700\" bgcolor=\"#FFFFFF\" ><tr><td style=\"line-height:0px;font-size:0px;mso-line-height-rule:exactly;\"><![endif]--><div style=\"background:#FFFFFF;background-color:#FFFFFF;margin:0px auto;max-width:700px;\"><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"background:#FFFFFF;background-color:#FFFFFF;width:100%;\"><tbody><tr><td style=\"direction:ltr;font-size:0px;padding:0;text-align:center;\"><!--[if mso | IE]><table role=\"presentation\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\"><tr><td class=\"\" style=\"vertical-align:top;width:700px;\" ><![endif]--><div class=\"mj-column-per-100 mj-outlook-group-fix\" style=\"font-size:0px;text-align:left;direction:ltr;display:inline-block;vertical-align:top;width:100%;\"><table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" width=\"100%\"><tbody><tr><td style=\"vertical-align:top;pa