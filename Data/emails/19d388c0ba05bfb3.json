  "body": "\r\n<!DOCTYPE html PUBLIC \"-//W3C//DTD XHTML 1.0 Transitional//EN\"\r\n        \"http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd\">\r\n<html xmlns=\"http://www.w3.org/1999/xhtml\" lang=\"en\">\r\n<head>\r\n    <meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\"/>\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no\"/>\r\n    <title>A new document from eBox</title>\r\n    <style type=\"text/css\">\r\n        html,\r\n        body,\r\n        table,\r\n        tbody,\r\n        tr,\r\n        td,\r\n        p {\r\n            margin: 0;\r\n            padding: 0;\r\n        }\r\n\r\n        body {\r\n            margin: 0;\r\n            padding: 0;\r\n            font-size: 0;\r\n            line-height: 0;\r\n            -ms-text-size-adjust: 100%;\r\n            -webkit-text-size-adjust: 100%;\r\n        }\r\n\r\n        table {\r\n            border-spacing: 0;\r\n            mso-table-lspace: 0pt;\r\n            mso-table-rspace: 0pt;\r\n        }\r\n\r\n        table td {\r\n            border-collapse: collapse;\r\n        }\r\n\r\n        img {\r\n            -ms-interpolation-mode: bicubic;\r\n        }\r\n\r\n        @media screen {\r\n            html,\r\n            body,\r\n            table,\r\n            tbody,\r\n            tr,\r\n            td,\r\n            p {\r\n                font-family: \"Open Sans\", Arial, sans-serif !important;\r\n            }\r\n\r\n            @font-face {\r\n                font-family: 'Open Sans';\r\n                font-style: normal;\r\n                font-weight: 400;\r\n                src: local('Open Sans Regular'), local('OpenSans-Regular'), url(https://fonts.gstatic.com/s/opensans/v15/cJZKeOuBrn4kERxqtaUH3VtXRa8TVwTICgirnJhmVJw.woff2) format('woff2');\r\n                unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02C6, U+02DA, U+02DC, U+2000-206F, U+2074, U+20AC, U+2212, U+2215;\r\n            }\r\n            @font-face {\r\n                font-family: 'Open Sans';\r\n                font-style: normal;\r\n                font-weight: 600;\r\n                src: local('Open Sans SemiBold'), local('OpenSans-SemiBold'), url(https://fonts.gstatic.com/s/opensans/v15/MTP_ySUJH_bn48VBG8sNSugdm0LZdjqr5-oayXSOefg.woff2) format('woff2');\r\n                unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02C6, U+02DA, U+02DC, U+2000-206F, U+2074, U+20AC, U+2212, U+2215;\r\n            }\r\n        }\r\n\r\n        @media screen and (max-width: 599px) {\r\n            #container600 {\r\n                display: block !important;\r\n                width: 100% !important;\r\n            }\r\n\r\n            .mobile-padding {\r\n                padding-left: 3% !important;\r\n                padding-right: 3% !important;\r\n            }\r\n        }\r\n\r\n        @media screen and (max-width: 320px) {\r\n            #container600 {\r\n                display: block !important;\r\n                width: 100% !important;\r\n            }\r\n\r\n            .mobile-padding {\r\n                padding-left: 0 !important;\r\n                padding-right: 0 !important;\r\n            }\r\n        }\r\n    </style>\r\n    <!--[if (mso)]>\r\n    <style type=\"text/css\">\r\n        a {\r\n            text-decoration: none;\r\n        }\r\n    </style>\r\n    <![endif]-->\r\n</head>\r\n<body style=\"background-color: #fff;\">\r\n<table bgcolor=\"#fff\" width=\"100%\" style=\"background-color: #fff; min-width: 100%\">\r\n    <tr>\r\n        <td width=\"100%\" style=\"background-color: #fff; min-width: 100%;\">\r\n            <center>\r\n                <table class=\"mobile-padding\" bgcolor=\"#fff\" cellpadding=\"0\" cellspacing=\"0\">\r\n                    <!-- Rainbow -->\r\n                    <tr>\r\n                        <td>\r\n                            <table cellpadding=\"0\" cellspacing=\"0\" width=\"100%\"\r\n                                   style=\"min-width: 100%; font-size: 0px;\">\r\n                                <tr>\r\n                                    <th bgcolor=\"#CF5620\" style=\"background-color: #CF5620; height: 4px;\">&nbsp;</th>\r\n                                    <th bgcolor=\"#F19C35\" style=\"background-color: #F19C35; height: 4px;\">&nbsp;</th>\r\n                                    <th bgcolor=\"#F8E047\" style=\"background-color: #F8E047; height: 4px;\">&nbsp;</th>\r\n                                    <th bgcolor=\"#91CD44\" style=\"background-color: #91CD44; height: 4px;\">&nbsp;</th>\r\n                                    <th bgcolor=\"#35C16E\" style=\"background-color: #35C16E; height: 4px;\">&nbsp;</th>\r\n                                    <th bgcolor=\"#4CBDE2\" style=\"background-color: #4CBDE2; height: 4px;\">&nbsp;</th>\r\n                                    <th bgcolor=\"#1F51AF\" style=\"background-color: #1F51AF; height: 4px;\">&nbsp;</th>\r\n                                </tr>\r\n                            </table>\r\n                        </td>\r\n                    </tr>\r\n                    <!-- END rainbow -->\r\n                    <tr>\r\n                        <td>\r\n                            <table id=\"container600\" class=\"mobile-padding\" bgcolor=\"#fff\" cellpadding=\"0\"\r\n                                   cellspacing=\"0\"\r\n                                   width=\"600\"\r\n                                   style=\"background-color: #ffffff; margin: 0 auto; padding: 0 30px;\">\r\n                                <!-- Mail content -->\r\n                                <tr>\r\n                                    <td align=\"left\" style=\"color: #4D4D4D; font-family: Open Sans, Arial, sans-serif; font-weight: 700; font-size: 18px; line-height: 28px; padding-top: 30px; padding-bottom: 20px;\">\r\n                                            Hello Denys,\r\n                                    </td>\r\n                                </tr>\r\n  