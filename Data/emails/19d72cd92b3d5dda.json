ble>\r\n           </td>\r\n       </tr>\r\n      </table>\r\n      \r\n      \r\n\r\n\r\n\r\n<!----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------BLOCK 3------------------------------------------------------------>\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n      <table width=\"100%\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" align=\"center\">\r\n        \r\n        <tr>\r\n           <td align=\"center\">\r\n            <table cellspacing=\"0\" cellpadding=\"0\" border=\"0\" width=\"390\" class=\"container\" align=\"center\">\r\n              <tr>\r\n                <td>\r\n                  <table style=\"background-color : transparent; border : 0px;font-size : 16px; font-family : Arial, helvetica, sans-serif; line-height : 150%; color : #45555D; \" class=\"tb_properties border_style\" cellspacing=\"0\" cellpadding=\"0\" bgcolor=\"transparent\" width=\"100%\">\r\n                    <tr>\r\n                      <td align=\"center\" valign=\"top\">\r\n                        <table align=\"left\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"100%\">\r\n                          <tr>\r\n                            <td class=\"content_padding\" style=\"border:0px;padding : 0px; \">\r\n                              <table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"100%\">\r\n                                <tr>\r\n                                  <td align=\"left\" class=\"header\" valign=\"top\">\r\n                                    <table cellpadding=\"0\" cellspacing=\"0\" width=\"100%\" role=\"presentation\" style=\"border: 0px; background-color: #FFFFFF; min-width: 100%; \" class=\"slot-styling\"><tr><td style=\"padding: 0px; \" class=\"slot-styling camarker-inner\"><table cellpadding=\"0\" cellspacing=\"0\" width=\"100%\" role=\"presentation\" class=\"stylingblock-content-wrapper\" style=\"min-width: 100%; \"><tr><td class=\"stylingblock-content-margin-cell\" style=\"padding: 0px 15px; \"><table cellpadding=\"0\" cellspacing=\"0\" width=\"100%\" role=\"presentation\" style=\"background-color: transparent; min-width: 100%; \" class=\"stylingblock-content-wrapper\"><tr><td style=\"padding: 20px 0px; \" class=\"stylingblock-content-wrapper camarker-inner\"><table width=\"100%\" cellspacing=\"0\" cellpadding=\"0\" role=\"presentation\"><tr><td align=\"center\">\r\n<a href=\"https://click.com.ethias.be/?%3D\" title=\"\"   data-linkto=\"https://\">\r\n<img data-assetid=\"154627\" src=\"https://image.com.ethias.be/lib/fe3d117075640475761670/m/1/b7c948c4-5d62-44c6-84a5-2b315ec1b74b.png\" alt=\"We zijn er voor je. Ethias.\" height=\"47\" width=\"180\" style=\"display: block; padding: 0px; text-align: center; height: 47px; width: 180px; border: 0px;\"></a></td></tr></table></td></tr></table></td></tr></table></td></tr></table>\r\n                                    \r\n                                  </td>\r\n                                </tr>\r\n                              </table>\r\n                            </td>\r\n                          </tr>\r\n                        </table>\r\n                      </td>\r\n                    </tr>\r\n                  </table>\r\n                </td>\r\n              </tr>\r\n            </table>\r\n           </td>\r\n       </tr>\r\n      </table>\r\n\r\n\r\n\r\n\r\n\r\n\r\n<!----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------BLOCK 4------------------------------------------------------------>\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n    <table width=\"100%\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" align=\"center\">\r\n        <tr>\r\n           <td align=\"center\">\r\n            <table cellspacing=\"0\" cellpadding=\"0\" border=\"0\" width=\"390\" class=\"container\" align=\"center\">\r\n              <tr>\r\n                <td>\r\n                  <table style=\"background-color : transparent; border : 0px;font-size : 16px; font-family : Arial, helvetica, sans-serif; line-height : 150%; color : #45555D; \" class=\"tb_properties border_style\" cellspacing=\"0\" cellpadding=\"0\" bgcolor=\"transparent\" width=\"100%\">\r\n                    <tr>\r\n                      <td align=\"center\" valign=\"top\">\r\n                        <table align=\"left\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"100%\">\r\n                          <tr>\r\n                            <td class=\"content_padding\" style=\"border:0px;padding : 0px; \">\r\n                              <table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"100%\">\r\n                                \r\n                                <tr>\r\n                                  <td align=\"left\" class=\"\" valign=\"top\">\r\n                                    <table cellpadding=\"0\" cellspacing=\"0\" width=\"100%\" role=\"presentation\" style=\"border: 0px; background-color: #FFFFFF; min-width: 100%; \" class=\"slot-styling\"><tr><td style=\"padding: 0px 0px 10px; \" class=\"slot-styling camarker-inner\"><table cellpadding=\"0\" cellspacing=\"0\" width=\"100%\" role=\"presentation\" style=\"min-width: 100%; \" class=\"stylingblock-content-wrapper\"><tr><td class=\"stylingblock-content-wrapper camarker-inner\"><table width=\"100%\" cellspacing=\"0\" cellpadding=\"0\" role=\"presentation\"><tr><td align=\"center\"><img data-assetid=\"176125\" src=\"https://image.com.ethias.be/lib/fe3d117075640475761670/m/1/c4adb38b-b643-47db-b521-378f3a1df90a.png\" alt=\"\" height=\"203\" width=\"390\" style=\"display: block; padding: 0px; text-align: center; height: 203px; width: 390px; border: 0px;\"></td></tr></table></td></tr></table>\r\n<table cellpadding=\"0\" cellspacing=\"0\" width=\"100%\" role=\"presentation\" style=\"background-color: transparent; min-width: 100%; \" class=\"stylingblock-content-wrapper\"><tr><td style=\"padding: 20px; \" class=\"stylingblock-content-wrapper camarker-inner\"><p style=\"font-family:'Fira sans', Arial, Helvetica, sans-serif; font-size: 18px; line-height: 26px; color: rgb(0, 0, 0); text-align: left;\">\r\n\tBeste Denys, </p><p style=\"font-family:'Fira sans', Arial, Helvetica, sans-serif; font-size: 18px; line-height: 26px; color: rgb(0, 0, 0); text-align: left;\">\r\n\tIn het leven zijn er duizend manieren om te tonen dat je om iemand geeft.<br>\r\n\tEen gebaar, een attentie, een troostend woord&hellip; en soms ook <b>een beslissing die je op tijd neemt</b>.<br>\r\n\t<br>\r\n\tWanneer een dierbare overlijdt, gaat het verdriet vaak gepaard met heel wat praktische regelingen en aanzienlijke kosten.<br>\r\n\tIn Belgi&euml; kost een uitvaart vandaag gemiddeld <b>tussen &euro;5.500 en &euro;6.500*</b>.<br>\r\n\t<br>\r\n\tDat zijn zorgen die zwaar kunnen wegen op de nabestaanden.<br>\r\n\tMet het <a   data-linkto=\"https://\" href=\"https://click.com.ethias.be/?%3D%3D\" style=\"color:#089EDD;text-decoration:underline;\" title=\"DELA-uitvaartzorgplan\">DELA-uitvaartzorgplan</a>**, aangeboden door Ethias, neem je een groot deel van die last weg bij je dierbaren op een moeilijk moment.</p></td></tr></table><table cellpadding=\"0\" cellspacing=\"0\" width=\"100%\" role=\"presentation\" style=\"background-color: transparent; min-width: 100%; \" class=\"stylingblock-content-wrapper\"><tr><td style=\"padding: 0px 20px; \" class=\"stylingblock-content-wrapper camarker-inner\">\r\n<table cellpadding=\"0\" cellspacing=\"0\" width=\"100%\" role=\"presentation\" style=\"background-color: #FFEFDC; min-width: 100%; border-radius:20px; \" class=\"stylingblock-content-wrapper\"><tr><td style=\"padding: 30px; \" class=\"stylingblock-content-wrapper camarker-inner\"><table cellspacing=\"0\" cellpadding=\"0\" role=\"presentation\" style=\"width: 100%;\"><tr><td><table cellspacing=\"0\" cellpadding=\"0\" role=\"presentation\" style=\"width: 100%;\"><tr><td valign=\"top\" class=\"responsive-td\" style=\"width: 100%; padding-bottom: 5px;\">\r\n<table cellpadding=\"0\" cellspacing=\"0\" width=\"100%\" role=\"presentation\" style=\"background-color: transparent; min-width: 100%; \" class=\"stylingblock-content-wrapper\"><tr><td style=\"padding: 0px 0px 20px; \" class=\"stylingblock-content-wrapper camarker-inner\"><table width=\"100%\" cellspacing=\"0\" cellpadding=\"0\" role=\"presentation\"><tr><td align=\"left\"><img data-assetid=\"175755\" src=\"https://image.com.ethias.be/lib/fe3d117075640475761670/m/1/d30f494d-1a3e-42b8-a6fd-3881487b5b6d.png\" alt=\"\" height=\"70\" width=\"70\" style=\"display: block; padding: 0px; text-align: left; height: 70px; width: 70px; border: 0px;\"></td></tr></table></td></tr></table><table cellpadding=\"0\" cellspacing=\"0\" width=\"100%\" role=\"presentation\" style=\"min-width: 100%; \" class=\"stylingblock-content-wrapper\"><tr>\r\n<td class=\"stylingblock-content-wrapper camarker-inner\"><p style=\"font-family:'Fira sans', Arial, Helvetica, sans-serif; font-size: 20px; line-height: 32px; color: rgb(0, 0, 0); color:#FF6F0D; text-align: left; font-weight: 700; text-transform:uppercase;\">\r\nWat is het DELA-uitvaarzorgplan?</p><p style=\"font-family:'Fira sans', Arial, Helvetica, sans-serif; font-size: 18px; line-height: 26px; color: rgb(0, 0, 0); text-align: left;\">\r\n Het laat je toe om:\r\n</p><ul style=\"font-family:'Fira sans', Arial, Helvetica, sans-serif; font-size: 18px; line-height: 26px; color: rgb(0, 0, 0); text-align: left;\">\r\n  <li>de <b>financiering van je uitvaart</b> te regelen,</li>\r\n    <li>je naasten moeilijke beslissingen te besparen,</li>\r\n    <li>hen <b>administratieve en menselijke ondersteuning</b> te bieden.</li>\r\n  </ul></td></tr></table><p style=\"font-family:'Fira sans', Arial, Helvetica, sans-serif; font-size: 18px; line-height: 26px; color: rgb(0, 0, 0); text-align: left;\">\r\n  Je kiest zelf:\r\n  </p><table role=\"presentation\" cellspacing=\"0\" cellpadding=\"0\" style=\"width:100%;\">\r\n  <tr>\r\n<td valign=\"top\" width=\"10%\" align=\"center\">\r\n  \r\n     <div style=\"height:10px; line-height:10px; font-size:10px;\">&nbsp;</div>\r\n      <img src=\"https://image.com.ethias.be/lib/fe3d117075640475761670/m/1/9caec790-8f16-4c8b-901f-b8067adbd4d2.png\" width=\"12\" height=\"11\" style=\"display:block;border:0;\">\r\n    </td>\r\n    <td valign=\"top\" width=\"90%\" style=\"padding:3px; font-family:'Fira Sans', Arial, Helvetica, sans-serif; font-size:18px; line-height:26px; color:#000;\">\r\nhet <b>verzekerde bedrag,</b>\r\n    </td>\r\n  </tr>\r\n\r\n   <tr>\r\n   <td valign=\"top\" width=\"10%\" align=\"center\">\r\n      <!-- Spacer -->\r\n      <div style=\"height:10px; line-height:10px; font-size:10px;\">&nbsp;</div>\r\n      <img src=\"https://image.com.ethias.be/lib/fe3d117075640475761670/m/1/9caec790-8f16-4c8b-901f-b8067adbd4d2.png\" width=\"12\" height=\"11\" style=\"display:block;border:0;\">\r\n    </td>\r\n    <td valign=\"top\" width=\"90%\" style=\"padding:3px; font-family:'Fira Sans', Arial, Helvetica, sans-serif; font-size:18px; line-height:26px; color:#000;\">\r\n    de <b>betalingsduur</b>,\r\n    </td>\r\n    </tr>\r\n  <tr>\r\n  <td valign=\"top\" width=\"10%\" align=\"center\">\r\n      <!-- Spacer -->\r\n      <div style=\"height:10px; line-height:10px; font-size:10px;\">&nbsp;</div>\r\n      <img src=\"https://image.com.ethias.be/lib/fe3d117075640475761670/m/1/9caec790-8f16-4c8b-901f-b8067adbd4d2.png\" width=\"12\" height=\"11\" style=\"display:block;border:0;\">\r\n    </td>\r\n    <td valign=\"top\" width=\"90%\" style=\"padding:3px; font-family:'Fira Sans', Arial, Helvetica, sans-serif; font-size:18px; line-height:26px; color:#000;\">\r\n   en de <b>begunstigde</b> (een naaste of de uitvaartondernemer).\r\n    </td>\r\n  </tr>\r\n  \r\n\r\n  </table><p style=\"font-family:'Fira sans', Arial, Helvetica, sans-serif; font-size: 1