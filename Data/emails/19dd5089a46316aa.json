  "body": "<!DOCTYPE html><html xmlns:v=\"urn:schemas-microsoft-com:vml\" xmlns:o=\"urn:schemas-microsoft-com:office:office\" lang=\"en\"><head><title></title><meta http-equiv=\"Content-Type\" content=\"text/html; charset=utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><!--[if mso]>\r\n<xml><w:WordDocument xmlns:w=\"urn:schemas-microsoft-com:office:word\"><w:DontUseAdvancedTypographyReadingMail/></w:WordDocument>\r\n<o:OfficeDocumentSettings><o:PixelsPerInch>96</o:PixelsPerInch><o:AllowPNG/></o:OfficeDocumentSettings></xml>\r\n<![endif]--><!--[if !mso]><!--><link href=\"https://fonts.googleapis.com/css2?family=Montserrat:wght@100;400;700;900&amp;display=swap\" rel=\"stylesheet\" type=\"text/css\"><!--<![endif]--><style>\r\n*{box-sizing:border-box}body{margin:0;padding:0}a[x-apple-data-detectors]{color:inherit!important;text-decoration:inherit!important}#MessageViewBody a{color:inherit;text-decoration:none}p{line-height:inherit}.desktop_hide,.desktop_hide table{mso-hide:all;display:none;max-height:0;overflow:hidden}.image_block img+div{display:none}sub,sup{font-size:75%;line-height:0} @media (max-width:520px){.row-content{width:100%!important}.stack .column{width:100%;display:block}.mobile_hide{min-height:0;max-height:0;max-width:0;display:none;overflow:hidden;font-size:0}.desktop_hide,.desktop_hide table{display:table!important;max-height:none!important}}\r\n</style><!--[if mso ]><style>sup, sub { font-size: 100% !important; } sup { mso-text-raise:10% } sub { mso-text-raise:-10% }</style> <![endif]--></head><body class=\"body\" style=\"margin:0;padding:0;-webkit-text-size-adjust:none;text-size-adjust:none;background-color:#fff\"><table class=\"nl-container\" width=\"100%\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"mso-table-lspace:0;mso-table-rspace:0;background-color:#fff\"><tbody><tr><td><table class=\"row row-1\" align=\"center\" \r\nwidth=\"100%\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"mso-table-lspace:0;mso-table-rspace:0;background-color:#fff\"><tbody><tr><td><table class=\"row-content stack\" align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"mso-table-lspace:0;mso-table-rspace:0;color:#000;width:500px;margin:0 auto\" width=\"500\"><tbody><tr><td class=\"column column-1\" width=\"100%\" \r\nstyle=\"mso-table-lspace:0;mso-table-rspace:0;font-weight:400;text-align:left;vertical-align:top\"><table width=\"100%\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"mso-table-lspace:0;mso-table-rspace:0\"><tr><td class=\"col-pad\" style=\"padding-bottom:5px;padding-top:10px\"><table class=\"text_block block-1\" width=\"100%\" border=\"0\" cellpadding=\"10\" cellspacing=\"0\" role=\"presentation\" style=\"mso-table-lspace:0;mso-table-rspace:0;word-break:break-word\"><tr><td class=\"pad\"><div \r\nstyle=\"font-family:Arial,sans-serif\"><div class style=\"font-family:Arial,'Helvetica Neue',Helvetica,sans-serif;font-size:12px;mso-line-height-alt:14.399999999999999px;color:#555;line-height:1.2\"><p style=\"margin:0;text-align:center;font-size:12px;mso-line-height-alt:14.399999999999999px\">\r\n<span style=\"word-break: break-word; color: #ffffff; font-size: 12px;\">Indien mail niet leesbaar,<strong><span style=\"word-break: break-word; font-size: 12px;\"> <a style=\"color:#ffffff;\" href=\"http://u1x2.mj.am/nl/u1x2/gr68l.html?m=AUkAAJdOx74AAc7mQ1AAALaUdv4AAYAJFIcAoO5CAAVpTQBp8OeTICuHPrXQSM-Wg01cAcKC_wAA-2M&amp;b=4c92cd65&amp;e=a47a2c99&amp;x=Ys-10zIS-bDDJ5qaHMVtp-vDo-UX1GRcCpFWdJN1vyq5jYWsAD2nNCVvPVn8fGWJ\">klik hier</a></span></strong>.</span></p></div></div></td></tr></table></td></tr></table></td></tr></tbody></table></td></tr></tbody></table><table class=\"row row-2\" align=\"center\" width=\"100%\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" \r\nrole=\"presentation\" style=\"mso-table-lspace:0;mso-table-rspace:0\"><tbody><tr><td><table class=\"row-content stack\" align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"mso-table-lspace:0;mso-table-rspace:0;color:#000;width:500px;margin:0 auto\" width=\"500\"><tbody><tr><td class=\"column column-1\" width=\"50%\" style=\"mso-table-lspace:0;mso-table-rspace:0;font-weight:400;text-align:left;vertical-align:top\"><table width=\"100%\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" \r\nrole=\"presentation\" style=\"mso-table-lspace:0;mso-table-rspace:0\"><tr><td class=\"col-pad\" style=\"padding-bottom:5px;padding-top:5px\"><table class=\"image_block block-1\" width=\"100%\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"mso-table-lspace:0;mso-table-rspace:0\"><tr><td class=\"pad\" style=\"width:100%\" align=\"center\"><div style=\"max-width:180px\"><img \r\nsrc=\"https://d15k2d11r6t6rl.cloudfront.net/public/users/Integrators/e1099da0-8a86-40f0-931c-74b00de291a8/abricasa/Abricasa%20-%20online%20-%20mini.jpg\" style=\"display:block;height:auto;border:0;width:100%\" width=\"180\" alt=\"Alternate text\" title=\"Alternate text\" height=\"auto\"></div></td></tr></table></td></tr></table></td><td class=\"column column-2\" width=\"50%\" style=\"mso-table-lspace:0;mso-table-rspace:0;font-weight:400;text-align:left;vertical-align:top\"><table width=\"100%\" border=\"0\" \r\ncellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"mso-table-lspace:0;mso-table-rspace:0\"><tr><td class=\"col-pad\" style=\"padding-bottom:5px;padding-top:5px\"><table class=\"image_block block-1\" width=\"100%\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"mso-table-lspace:0;mso-table-rspace:0\"><tr><td class=\"pad\" style=\"width:100%\" align=\"center\"><div style=\"max-width:199px\"><img \r\nsrc=\"https://d15k2d11r6t6rl.cloudfront.net/public/users/Integrators/e1099da0-8a86-40f0-931c-74b00de291a8/abricasa/Eigenaarsbond%20-%20Logo%20-%202.jpg\" style=\"display:block;height:auto;border:0;width:100%\" width=\"199\" alt=\"Alternate text\" title=\"Alternate text\" height=\"auto\"></div></td></tr></table></td></tr></table></td></tr></tbody></table></td></tr></tbody></table><table class=\"row row-3\" align=\"center\" width=\"100%\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" \r\nstyle=\"mso-table-lspace:0;mso-table-rspace:0\"><tbody><tr><td><table class=\"row-content stack\" align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"mso-table-lspace:0;mso-table-rspace:0;color:#000;width:500px;margin:0 auto\" width=\"500\"><tbody><tr><td class=\"column column-1\" width=\"100%\" style=\"mso-table-lspace:0;mso-table-rspace:0;font-weight:400;text-align:left;vertical-align:top\"><table width=\"100%\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" \r\nstyle=\"mso-table-lspace:0;mso-table-rspace:0\"><tr><td class=\"col-pad\" style=\"padding-bottom:5px;padding-top:5px\"><table class=\"text_block block-1\" width=\"100%\" border=\"0\" cellpadding=\"10\" cellspacing=\"0\" role=\"presentation\" style=\"mso-table-lspace:0;mso-table-rspace:0;word-break:break-word\"><tr><td class=\"pad\"><div style=\"font-family:'Trebuchet MS',Tahoma,sans-serif\"><div class \r\nstyle=\"font-size:14px;font-family:Montserrat,'Trebuchet MS','Lucida Grande','Lucida Sans Unicode','Lucida Sans',Tahoma,sans-serif;mso-line-height-alt:16.8px;color:#555;line-height:1.2\"><p style=\"margin:0;mso-line-height-alt:16.8px\">Beste,</p><p style=\"margin:0;mso-line-height-alt:16.8px\">&nbsp;</p><p style=\"margin:0;mso-line-height-alt:16.8px\">\r\nEén van de mooie voordelen van mijn rol als bestuurder van Abricasa én voorzitster van De Eigenaarsbond, is dat ik jullie vanop de eerste rij kan meenemen in de activiteiten van De Eigenaarsbond.</p><p style=\"margin:0;mso-line-height-alt:16.8px\">&nbsp;</p><p style=\"margin:0;mso-line-height-alt:16.8px\">Bij De Eigenaarsbond zetten we ons dagelijks in voor de belangen van vastgoedeigenaars, dit rond verhuur en mede-eigendom.</p><p style=\"margin:0;mso-line-height-alt:16.8px\">&nbsp;</p><p \r\nstyle=\"margin:0;mso-line-height-alt:16.8px\">Naar aanleiding van het 85-jarig bestaan organiseert De Eigenaarsbond in mei en juni maar liefst 9 webinars, boordevol waardevolle inzichten.</p><p style=\"margin:0;mso-line-height-alt:16.8px\">&nbsp;</p><p style=\"margin:0;mso-line-height-alt:16.8px\">Hieronder vinden jullie alvast een overzicht van de infosessies in mei.</p><p style=\"margin:0;mso-line-height-alt:16.8px\">&nbsp;</p><p style=\"margin:0;mso-line-height-alt:16.8px\">\r\nWees er snel bij en schrijf jullie in!</p><p style=\"margin:0;mso-line-height-alt:16.8px\">&nbsp;</p><p style=\"margin:0;mso-line-height-alt:16.8px\">Tot dan ;-)</p><p style=\"margin:0;mso-line-height-alt:16.8px\">&nbsp;</p><p style=\"margin:0;mso-line-height-alt:16.8px\">Met positieve groeten,<br>Milla Dieltjens</p><p style=\"margin:0;mso-line-height-alt:16.8px\">Erkend vastgoedmakelaar&nbsp;</p><p style=\"margin:0;mso-line-height-alt:16.8px\">voorzitster De Eigenaarsbond</p></div></div></td></tr></table>\r\n</td></tr></table></td></tr></tbody></table></td></tr></tbody></table><table class=\"row row-4\" align=\"center\" width=\"100%\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"mso-table-lspace:0;mso-table-rspace:0\"><tbody><tr><td><table class=\"row-content stack\" align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"mso-table-lspace:0;mso-table-rspace:0;color:#000;width:500px;margin:0 auto\" width=\"500\"><tbody><tr><td class=\"column column-1\" \r\nwidth=\"100%\" style=\"mso-table-lspace:0;mso-table-rspace:0;font-weight:400;text-align:left;vertical-align:top\"><table width=\"100%\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"mso-table-lspace:0;mso-table-rspace:0\"><tr><td class=\"col-pad\" style=\"padding-bottom:5px;padding-top:5px\"><table class=\"heading_block block-1\" width=\"100%\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"mso-table-lspace:0;mso-table-rspace:0\"><tr><td class=\"pad\" \r\nstyle=\"width:100%\" align=\"center\"><h1 style=\"margin:0;color:#555;direction:ltr;font-family:Arial,Helvetica Neue,Helvetica,sans-serif;font-size:16px;font-weight:700;letter-spacing:normal;line-height:1.2;text-align:left;margin-top:0;margin-bottom:0;mso-line-height-alt:19px\"><span class=\"tinyMce-placeholder\" style=\"word-break: break-word;\"><strong>Wat niemand je vertelt over de wet op mede-eigendom</strong><br>6 mei 2026 - 12u30 - 14u</span></h1></td></tr></table><table class=\"text_block block-2\" \r\nwidth=\"100%\" border=\"0\" cellpadding=\"10\" cellspacing=\"0\" role=\"presentation\" style=\"mso-table-lspace:0;mso-table-rspace:0;word-break:break-word\"><tr><td class=\"pad\"><div style=\"font-family:'Trebuchet MS',Tahoma,sans-serif\"><div class style=\"font-family:Montserrat,'Trebuchet MS','Lucida Grande','Lucida Sans Unicode','Lucida Sans',Tahoma,sans-serif;font-size:12px;mso-line-height-alt:14.399999999999999px;color:#555;line-height:1.2\"><p style=\"margin:0;mso-line-height-alt:14.399999999999999px\">\r\nHeb je je ooit al afgevraagd waarom beslissingen in je VME soms zo ingewikkeld zijn?<br>Waarom bepaalde regels strikt lijken, terwijl andere net ruimte laten voor discussie?</p><p style=\"margin:0;mso-line-height-alt:14.399999999999999px\">Dat is geen toeval. De wet op de mede-eigendom is doorheen de jaren gegroeid, aangepast en bijgestuurd. Maar die evolutie is voor de meeste mede-eigenaars en zelfs syndici allesbehalve duidelijk.</p><p style=\"margin:0;mso-line-height-alt:14.399999999999999px\">\r\nDaardoor ontstaan er vandaag nog vaak misverstanden, discussies en soms ook verkeerde beslissingen binnen VME’s.</p></div></div></td></tr></table><table class=\"button_block block-3\" width=\"100%\" border=\"0\" cellpadding=\"5\" cellspacing=\"0\" role=\"presentation\" style=\"mso-table-lspace:0;mso-table-rspace:0\"><tr><td class=\"pad\" align=\"center\"><a href=\"http://u1x2.mj.am/lnk/AUkAAJdOx74AAc7mQ1AAALaUdv4AAYAJFIcAoO5CAAVpTQBp8OeTICuHPrXQSM-Wg01cAcKC_wAA-2M/1/qQlfIDEKX9R9JCyT1ddl_A/aHR0cHM6Ly93d3cuZWlnZW5hYXJzYm9uZC5iZS9ldmVudC93YXQtbmllbWFuZC1qZS12ZXJ0ZWx0LW92ZXItZGUtd2V0LW9wLW1lZGUtZWlnZW5kb20v\" target=\"_blank\" style=\"color:#ffffff;text-decoration:none;\"><!--[if mso]>\r\n<v:roundrect xmlns:v=\"urn:schemas-microsoft-com:vml\" xmlns:w=\"urn:schemas-microsoft-com:office:word\"  href=\"https://www.eigenaarsbond.be/event/wat-niemand-je-vertelt-over-de-wet-op-mede-eigendom/\"  style=\"height:34px;width:274px;v-text-anchor:middle;\" arcsize=\"6%\" fillcolor=\"#d61a59\">\r\n<v:stroke dashstyle=\"Solid\" weight=\"0px\" color=\"#d61a59\"/>\r\n<w:anchorlock/>\r\n<v:textbox inset=\"0px,0px,0px,0px\">\r\n<center dir=\"false\" style=\"color:#ffffff;font-family:'Trebuchet MS', Tahoma, sans-serif;font-size:12px\">\r\n<![endif]-->\r\n<span class=\"button\" style=\"background-color: #d61a59; border-bottom: 0px solid transparent; border-left: 0px solid transparent; border-radius: 2px; border-right: 0px solid transparent; border-top: 0px solid transparent; color: #ffffff; display: inline-block; font-family: 'Montserrat', 'Trebuchet MS', 'Lucida Grande', 'Lucida Sans Unicode', 'Lucida Sans', Tahoma, sans-serif; font-size: 12px; font-weight: undefined; mso-border-alt: none; text-align: center; width: auto; word-break: keep-all; letter-spacing: normal;\"><span class=\"btn-pad\" style=\"word-break: break-word; padding-left: 20px; padding-right: 20px; padding-top: 5px; padding-bottom: 5px; display: block;\"><span style=\"word-break: break-word; line-height: 24px;\"><strong>Voor meer informatie en inschrijvingen</strong></span></span></span>\r\n<!--[if mso]></center></v:textbox></v:roundrect><![endif]--></a></td></tr></table><table class=\"divider_block block-4\" width=\"100%\" border=\"0\" cellpadding=\"10\" cellspacing=\"0\" role=\"presentation\" style=\"mso-table-lspace:0;mso-table-rspace:0\"><tr><td class=\"pad\" align=\"center\"><table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" width=\"100%\" style=\"mso-table-lspace:0;mso-table-rspace:0\"><tr><td class=\"divider_inner\" style=\"font-size:1px;line-height:1px;border-top:1px solid #bbb\">\r\n<span style=\"word-break: break-word;\">&#8202;</span></td></tr></table></td></tr></table></td></tr></table></td></tr></tbody></table></td></tr></tbody></table><table class=\"row row-5\" align=\"center\" width=\"100%\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"mso-table-lspace:0;mso-table-rspace:0\"><tbody><tr><td><table class=\"row-content stack\" align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" \r\nstyle=\"mso-table-lspace:0;mso-table-rspace:0;color:#000;width:500px;margin:0 auto\" width=\"500\"><tbody><tr><td class=\"column column-1\" width=\"100%\" style=\"mso-table-lspace:0;mso-table-rspace:0;font-weight:400;text-align:left;vertical-align:top\"><table width=\"100%\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"mso-table-lspace:0;mso-table-rspace:0\"><tr><td class=\"col-pad\" style=\"padding-bottom:5px;padding-top:5px\"><table class=\"heading_block block-1\" width=\"100%\" \r\nborder=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"mso-table-lspace:0;mso-table-rspace:0\"><tr><td class=\"pad\" style=\"width:100%\" align=\"center\"><h1 style=\"margin:0;color:#555;direction:ltr;font-family:Arial,Helvetica Neue,Helvetica,sans-serif;font-size:16px;font-weight:700;letter-spacing:normal;line-height:1.2;text-align:left;margin-top:0;margin-bottom:0;mso-line-height-alt:19px\">\r\n<span class=\"tinyMce-placeholder\" style=\"word-break: break-word;\"><strong>Huurrecht in België: één kader, meerdere regels</strong><br>13 mei 2026 - 12u30 - 14u</span></h1></td></tr></table><table class=\"text_block block-2\" width=\"100%\" border=\"0\" cellpadding=\"10\" cellspacing=\"0\" role=\"presentation\" style=\"mso-table-lspace:0;mso-table-rspace:0;word-break:break-word\"><tr><td class=\"pad\"><div style=\"font-family:'Trebuchet MS',Tahoma,sans-serif\"><div class \r\nstyle=\"font-family:Montserrat,'Trebuchet MS','Lucida Grande','Lucida Sans Unicode','Lucida Sans',Tahoma,sans-serif;font-size:12px;mso-line-height-alt:14.399999999999999px;color:#555;line-height:1.2\"><p style=\"margin:0;mso-line-height-alt:14.399999999999999px\">Wie een pand verhuurt, merkt al snel dat het huurrecht in België niet zo eenduidig is als het lijkt.</p><p style=\"margin:0;mso-line-height-alt:14.399999999999999px\">\r\nContracten, opzegregels, huurwaarborg… het lijkt allemaal duidelijk, tot je merkt dat niet overal dezelfde regels gelden. Wat federaal bepaald is, wordt op andere vlakken aangevuld of anders ingevuld per gewest.</p><p style=\"margin:0;mso-line-height-alt:14.399999999999999px\">Daardoor verliezen veel verhuurders het overzicht. En net dat zorgt in de praktijk voor twijfel, misverstanden en soms ook verkeerde beslissingen.</p></div></div></td></tr></table><table class=\"button_block block-3\" \r\nwidth=\"100%\" border=\"0\" cellpadding=\"5\" cellspacing=\"0\" role=\"presentation\" style=\"mso-table-lspace:0;mso-table-rspace:0\"><tr><td class=\"pad\" align=\"center\"><a href=\"http://u1x2.mj.am/lnk/AUkAAJdOx74AAc7mQ1AAALaUdv4AAYAJFIcAoO5CAAVpTQBp8OeTICuHPrXQSM-Wg01cAcKC_wAA-2M/2/hZiYJsI8IfrnnsSOUULXew/aHR0cHM6Ly93d3cuZWlnZW5hYXJzYm9uZC5iZS9ldmVudC9odXVycmVjaHQtaW4tYmVsZ2llLWVlbi1rYWRlci1tZWVyZGVyZS1yZWdlbHMv\" target=\"_blank\" style=\"color:#ffffff;text-decoration:none;\"><!--[if mso]>\r\n<v:roundrect xmlns:v=\"urn:schemas-microsoft-com:vml\" xmlns:w=\"urn:schemas-microsoft-com:office:word\"  href=\"https://www.eigenaarsbond.be/event/huurrecht-in-belgie-een-kader-meerdere-regels/\"  style=\"height:34px;width:274px;v-text-anchor:middle;\" arcsize=\"6%\" fillcolor=\"#d61a59\">\r\n<v:stroke dashstyle=\"Solid\" weight=\"0px\" color=\"#d61a59\"/>\r\n<w:anchorlock/>\r\n<v:textbox inset=\"0px,0px,0px,0px\">\r\n<center dir=\"false\" style=\"color:#ffffff;font-family:'Trebuchet MS', Tahoma, sans-serif;font-size:12px\">\r\n<![endif]-->\r\n<span class=\"button\" style=\"background-color: #d61a59; border-bottom: 0px solid transparent; border-left: 0px solid transparent; border-radius: 2px; border-right: 0px solid transparent; border-top: 0px solid transparent; color: #ffffff; display: inline-block; font-family: 'Montserrat', 'Trebuchet MS', 'Lucida Grande', 'Lucida Sans Unicode', 'Lucida Sans', Tahoma, sans-serif; font-size: 12px; font-weight: undefined; mso-border-alt: none; text-align: center; width: auto; word-break: keep-all; letter-spacing: normal;\"><span class=\"btn-pad\" style=\"word-break: break-word; padding-left: 20px; padding-right: 20px; padding-top: 5px; padding-bottom: 5px; display: block;\"><span style=\"word-break: break-word; line-height: 24px;\"><strong>Voor meer informatie en inschrijvingen</strong></span></span></span>\r\n<!--[if mso]></center></v:textbox></v:roundrect><![endif]--></a></td></tr></table><table class=\"divider_block block-4\" width=\"100%\" border=\"0\" cellpadding=\"10\" cellspacing=\"0\" role=\"presentation\" style=\"mso-table-lspace:0;mso-table-rspace:0\"><tr><td class=\"pad\" align=\"center\"><table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" width=\"100%\" style=\"mso-table-lspace:0;mso-table-rspace:0\"><tr><td class=\"divider_inner\" style=\"font-size:1px;line-height:1px;border-top:1px solid #bbb\">\r\n<span style=\"word-break: break-word;\">&#8202;</span></td></tr></table></td></tr></table></td></tr></table></td></tr></tbody></table></td></tr></tbody></table><table class=\"row row-6\" align=\"center\" width=\"100%\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"mso-table-lspace:0;mso-table-rspace:0\"><tbody><tr><td><table class=\"row-content stack\" align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" \r\nstyle=\"mso-table-lspace:0;mso-table-rspace:0;color:#000;width:500px;margin:0 auto\" width=\"500\"><tbody><tr><td class=\"column column-1\" width=\"100%\" style=\"mso-table-lspace:0;mso-table-rspace:0;font-weight:400;text-align:left;vertical-align:top\"><table width=\"100%\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"mso-table-lspace:0;mso-table-rspace:0\"><tr><td class=\"col-pad\" style=\"padding-bottom:5px;padding-top:5px\"><table class=\"heading_block block-1\" width=\"100%\" \r\nborder=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"mso-table-lspace:0;mso-table-rspace:0\"><tr><td class=\"pad\" style=\"width:100%\" align=\"center\"><h1 style=\"margin:0;color:#555;direction:ltr;font-family:Arial,Helvetica Neue,Helvetica,sans-serif;font-size:16px;font-weight:700;letter-spacing:normal;line-height:1.2;text-align:left;margin-top:0;margin-bottom:0;mso-line-height-alt:19px\">\r\n<span class=\"tinyMce-placeholder\" style=\"word-break: break-word;\"><strong>Geen VME in jullie gebouw.. Mag dat?</strong><br>21 mei 2026 - 12u30 - 14u00</span></h1></td></tr></table><table class=\"text_block block-2\" width=\"100%\" border=\"0\" cellpadding=\"10\" cellspacing=\"0\" role=\"presentation\" style=\"mso-table-lspace:0;mso-table-rspace:0;word-break:break-word\"><tr><td class=\"pad\"><div style=\"font-family:'Trebuchet MS',Tahoma,sans-serif\"><div class \r\nstyle=\"font-family:Montserrat,'Trebuchet MS','Lucida Grande','Lucida Sans Unicode','Lucida Sans',Tahoma,sans-serif;font-size:12px;mso-line-height-alt:14.399999999999999px;color:#555;line-height:1.2\"><p style=\"margin:0;mso-line-height-alt:14.399999999999999px\">In veel kleinere appartementsgebouwen is er geen VME.<br>Alles wordt onderling geregeld, vaak vrij informeel.<br>Dat werkt… tot het niet meer werkt.<br>\r\nBij kosten, werken of meningsverschillen wordt al snel duidelijk dat er geen duidelijke structuur is.<br>En dan rijst de vraag: wat is hier eigenlijk wettelijk verplicht?</p></div></div></td></tr></table><table class=\"button_block block-3\" width=\"100%\" border=\"0\" cellpadding=\"5\" cellspacing=\"0\" role=\"presentation\" style=\"mso-table-lspace:0;mso-table-rspace:0\"><tr><td class=\"pad\" align=\"center\">\r\n<a href=\"http://u1x2.mj.am/lnk/AUkAAJdOx74AAc7mQ1AAALaUdv4AAYAJFIcAoO5CAAVpTQBp8OeTICuHPrXQSM-Wg01cAcKC_wAA-2M/3/vr2gGeaI2O159VnZDanveQ/aHR0cHM6Ly93d3cuZWlnZW5hYXJzYm9uZC5iZS9ldmVudC9nZWVuLXZtZS1pbi1qdWxsaWUtZ2Vib3V3LW1hZy1kYXQv\" target=\"_blank\" style=\"color:#ffffff;text-decoration:none;\"><!--[if mso]>\r\n<v:roundrect xmlns:v=\"urn:schemas-microsoft-com:vml\" xmlns:w=\"urn:schemas-microsoft-com:office:word\"  href=\"https://www.eigenaarsbond.be/event/geen-vme-in-jullie-gebouw-mag-dat/\"  style=\"height:34px;width:274px;v-text-anchor:middle;\" arcsize=\"6%\" fillcolor=\"#d61a59\">\r\n<v:stroke dashstyle=\"Solid\" weight=\"0px\" color=\"#d61a59\"/>\r\n<w:anchorlock/>\r\n<v:textbox inset=\"0px,0px,0px,0px\">\r\n<center dir=\"false\" style=\"color:#ffffff;font-family:'Trebuchet MS', Tahoma, sans-serif;font-size:12px\">\r\n<![endif]-->\r\n<span class=\"button\" style=\"background-color: #d61a59; border-bottom: 0px solid transparent; border-left: 0px solid transparent; border-radius: 2px; border-right: 0px solid transparent; border-top: 0px solid transparent; color: #ffffff; display: inline-block; font-family: 'Montserrat', 'Trebuchet MS', 'Lucida Grande', 'Lucida Sans Unicode', 'Lucida Sans', Tahoma, sans-serif; font-size: 12px; font-weight: undefined; mso-border-alt: none; text-align: center; width: auto; word-break: keep-all; letter-spacing: normal;\"><span class=\"btn-pad\" style=\"word-break: break-word; padding-left: 20px; padding-right: 20px; padding-top: 5px; padding-bottom: 5px; display: block;\"><span style=\"word-break: break-word; line-height: 24px;\"><strong>Voor meer informatie en inschrijvingen</strong></span></span></span>\r\n<!--[if mso]></center></v:textbox></v:roundrect><![endif]--></a></td></tr></table><table class=\"divider_block block-4\" width=\"100%\" border=\"0\" cellpadding=\"10\" cellspacing=\"0\" role=\"presentation\" style=\"mso-table-lspace:0;mso-table-rspace:0\"><tr><td class=\"pad\" align=\"center\"><table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" width=\"100%\" style=\"mso-table-lspace:0;mso-table-rspace:0\"><tr><td class=\"divider_inner\" style=\"font-size:1px;line-height:1px;border-top:1px solid #bbb\">\r\n<span style=\"word-break: break-word;\">&#8202;</span></td></tr></table></td></tr></table></td></tr></table></td></tr></tbody></table></td></tr></tbody></table><table class=\"row row-7\" align=\"center\" width=\"100%\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"mso-table-lspace:0;mso-table-rspace:0\"><tbody><tr><td><table class=\"row-content stack\" align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" \r\nstyle=\"mso-table-lspace:0;mso-table-rspace:0;color:#000;width:500px;margin:0 auto\" width=\"500\"><tbody><tr><td class=\"column column-1\" width=\"100%\" style=\"mso-table-lspace:0;mso-table-rspace:0;font-weight:400;text-align:left;vertical-align:top\"><table width=\"100%\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"mso-table-lspace:0;mso-table-rspace:0\"><tr><td class=\"col-pad\" style=\"padding-bottom:5px;padding-top:5px\"><table class=\"heading_block block-1\" width=\"100%\" \r\nborder=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"mso-table-lspace:0;mso-table-rspace:0\"><tr><td class=\"pad\" style=\"width:100%\" align=\"center\"><h1 style=\"margin:0;color:#555;direction:ltr;font-family:Arial,Helvetica Neue,Helvetica,sans-serif;font-size:16px;font-weight:700;letter-spacing:normal;line-height:1.2;text-align:left;margin-top:0;margin-bottom:0;mso-line-height-alt:19px\">\r\n<span class=\"tinyMce-placeholder\" style=\"word-break: break-word;\"><strong>Achterstallige huur: wacht niet te lang</strong><br>28 mei 2026 - 12u30 - 14u00</span></h1></td></tr></table><table class=\"text_block block-2\" width=\"100%\" border=\"0\" cellpadding=\"10\" cellspacing=\"0\" role=\"presentation\" style=\"mso-table-lspace:0;mso-table-rspace:0;word-break:break-word\"><tr><td class=\"pad\"><div style=\"font-family:'Trebuchet MS',Tahoma,sans-serif\"><div class \r\nstyle=\"font-size:12px;font-family:Montserrat,'Trebuchet MS','Lucida Grande','Lucida Sans Unicode','Lucida Sans',Tahoma,sans-serif;mso-line-height-alt:14.399999999999999px;color:#555;line-height:1.2\"><p style=\"margin:0;mso-line-height-alt:14.399999999999999px\">De huur blijft uit.<br>Eerst een paar dagen, dan weken… en voor je het weet zit je met een achterstand.</p><p style=\"margin:0;mso-line-height-alt:14.399999999999999px\">\r\nAls verhuurder wil je correct handelen, maar tegelijk ook geen tijd verliezen.<br>Wanneer stuur je een aanmaning? Wanneer zet je de volgende stap? En wanneer schakel je de rechtbank in?</p><p style=\"margin:0;mso-line-height-alt:14.399999999999999px\">Zonder duidelijk plan is het moeilijk om te weten wat je best doet. En net daardoor wordt er vaak te lang gewacht of verkeerd gehandeld.</p></div></div></td></tr></table><table class=\"button_block block-3\" width=\"100%\" border=\"0\" cellpadding=\"5\" \r\ncellspacing=\"0\" role=\"presentation\" style=\"mso-table-lspace:0;mso-table-rspace:0\"><tr><td class=\"pad\" align=\"center\"><a href=\"http://u1x2.mj.am/lnk/AUkAAJdOx74AAc7mQ1AAALaUdv4AAYAJFIcAoO5CAAVpTQBp8OeTICuHPrXQSM-Wg01cAcKC_wAA-2M/4/Y6f2KYzB2XwAXgKH-5GeYg/aHR0cHM6Ly93d3cuZWlnZW5hYXJzYm9uZC5iZS9ldmVudC9hY2h0ZXJzdGFsbGlnZS1odXVyLXdhY2h0LW5pZXQtdGUtbGFuZy8\" target=\"_blank\" style=\"color:#ffffff;text-decoration:none;\"><!--[if mso]>\r\n<v:roundrect xmlns:v=\"urn:schemas-microsoft-com:vml\" xmlns:w=\"urn:schemas-microsoft-com:office:word\"  href=\"https://www.eigenaarsbond.be/event/achterstallige-huur-wacht-niet-te-lang/\"  style=\"height:34px;width:274px;v-text-anchor:middle;\" arcsize=\"6%\" fillcolor=\"#d61a59\">\r\n<v:stroke dashstyle=\"Solid\" weight=\"0px\" color=\"#d61a59\"/>\r\n<w:anchorlock/>\r\n<v:textbox inset=\"0px,0px,0px,0px\">\r\n<center dir=\"false\" style=\"color:#ffffff;font-family:'Trebuchet MS', Tahoma, sans-serif;font-size:12px\">\r\n<![endif]-->\r\n<span class=\"button\" style=\"background-color: #d61a59; border-bottom: 0px solid transparent; border-left: 0px solid transparent; border-radius: 2px; border-right: 0px solid transparent; border-top: 0px solid transparent; color: #ffffff; display: inline-block; font-family: 'Montserrat', 'Trebuchet MS', 'Lucida Grande', 'Lucida Sans Unicode', 'Lucida Sans', Tahoma, sans-serif; font-size: 12px; font-weight: undefined; mso-border-alt: none; text-align: center; width: auto; word-break: keep-all; letter-spacing: normal;\"><span class=\"btn-pad\" style=\"word-break: break-word; padding-left: 20px; padding-right: 20px; padding-top: 5px; padding-bottom: 5px; display: block;\"><span style=\"word-break: break-word; line-height: 24px;\"><strong>Voor meer informatie en inschrijvingen</strong></span></span></span>\r\n<!--[if mso]></center></v:textbox></v:roundrect><![endif]--></a></td></tr></table><table class=\"divider_block block-4\" width=\"100%\" border=\"0\" cellpadding=\"10\" cellspacing=\"0\" role=\"presentation\" style=\"mso-table-lspace:0;mso-table-rspace:0\"><tr><td class=\"pad\" align=\"center\"><table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" width=\"100%\" style=\"mso-table-lspace:0;mso-table-rspace:0\"><tr><td class=\"divider_inner\" style=\"font-size:1px;line-height:1px;border-top:1px solid #bbb\">\r\n<span style=\"word-break: break-word;\">&#8202;</span></td></tr></table></td></tr></table></td></tr></table></td></tr></tbody></table></td></tr></tbody></table><table class=\"row row-8\" align=\"center\" width=\"100%\" border=\"0\" cellpadding=\"0\" cellspacing=