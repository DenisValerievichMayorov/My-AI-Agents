\r\n  table,\r\n  td,\r\n  a {\r\n    -ms-text-size-adjust: 100%; /* 1 */\r\n    -webkit-text-size-adjust: 100%; /* 2 */\r\n    font-family: 'OpenAI Sans', Helvetica, Arial, sans-serif;\r\n  }\r\n\r\n  /**\r\n   * Remove extra space added to tables and cells in Outlook.\r\n   */\r\n  table,\r\n  td {\r\n    mso-table-rspace: 0pt;\r\n    mso-table-lspace: 0pt;\r\n    vertical-align: top; /* Align content to the top of table cells */\r\n  }\r\n\r\n  /**\r\n   * Better fluid images in Internet Explorer.\r\n   */\r\n  img {\r\n    -ms-interpolation-mode: bicubic;\r\n  }\r\n\r\n  /**\r\n   * Remove blue links for iOS devices.\r\n   */\r\n  a[x-apple-data-detectors] {\r\n    font-family: inherit !important;\r\n    font-size: inherit !important;\r\n    font-weight: inherit !important;\r\n    line-height: inherit !important;\r\n    color: inherit !important;\r\n    text-decoration: none !important;\r\n  }\r\n\r\n  /**\r\n   * Fix centering issues in Android 4.4.\r\n   */\r\n  div[style*=\"margin: 16px 0;\"] {\r\n    margin: 0 !important;\r\n  }\r\n\r\n  body {\r\n    width: 100% !important;\r\n    height: 100% !important;\r\n    padding: 0 !important;\r\n    margin: 0 !important;\r\n  }\r\n\r\n  /**\r\n   * Collapse table borders to avoid space between cells.\r\n   */\r\n  table {\r\n    border-collapse: collapse !important;\r\n  }\r\n\r\n  a {\r\n    color: #898A8D;\r\n  }\r\n\r\n  .image-reset-bullets,\r\n  .image-reset-bullets .email-bullet-link {\r\n      color: #000000;\r\n  }\r\n\r\n  /* Give the ChatGPT logo pill consistent breathing room in light mode. */\r\n  .email-logo-pill {\r\n      background-color: #ffffff;\r\n      border-radius: 12px;\r\n      padding: 13px;\r\n      display: inline-block;\r\n  }\r\n\r\n  img {\r\n    height: auto;\r\n    line-height: 100%;\r\n    text-decoration: none;\r\n    border: 0;\r\n    outline: none;\r\n  }\r\n\r\n  /* Composer image sizing (mobile default) */\r\n  .composer-img {\r\n      width: 83px !important;\r\n      height: auto !important;\r\n      padding: 16px !important;\r\n  }\r\n\r\n  h1 {\r\n      font-size: 34px;\r\n      line-height: 41px;\r\n      font-weight: 400;\r\n      letter-spacing: 0.4px;\r\n      margin: 0;\r\n  }\r\n  h2 {\r\n      font-size: 18px;\r\n      font-weight: 400;\r\n      margin: 0;\r\n      line-height: 150%;\r\n      letter-spacing: -0.2px;\r\n  }\r\n  p {\r\n      font-size: 16px;\r\n      line-height: 130%;\r\n      font-weight: 500;\r\n      margin: 0;\r\n  }\r\n  p + p {\r\n      margin-top: 16px;\r\n  }\r\n  /* Intro blocks (H1/H2) sizing */\r\n  .intro-block {\r\n      width: 345px !important;\r\n      max-width: 345px !important;\r\n  }\r\n  /* Composer card sizing */\r\n  .composer-card {\r\n      width: 377px !important;\r\n      max-width: 377px !important;\r\n  }\r\n  /* Button styling */\r\n  a.button {\r\n      background-color: #000000 !important; /* default black */\r\n      border-radius: 24px !important; /* make button curvy */\r\n      padding: 11.5px 24px 11.5px !important; /* bigger size */\r\n      font-size: 16px !important; /* revert text size */\r\n      line-height: 24px !important;\r\n  }\r\n\r\n  a.button:active {\r\n      background-color: #414141 !important; /* dark gray on click */\r\n      border-radius: 36px !important;\r\n  }\r\n  /* CTA button hover state (supported clients only) */\r\n  a.button-invert:hover,\r\n  a.button-invert:focus {\r\n      background-color: #000000 !important;\r\n      color: #FFFFFF !important;\r\n      border-color: #FFFFFF !important;\r\n  }\r\n  a.button-invert:hover span,\r\n  a.button-invert:focus span {\r\n      color: #FFFFFF !important;\r\n  }\r\n  @media (prefers-color-scheme: dark) {\r\n      a.button-invert {\r\n          background-color: #FFFFFF !important;\r\n          color: #000000 !important;\r\n          border-color: #FFFFFF !important;\r\n          -webkit-text-fill-color: #000000 !important;\r\n      }\r\n      a.button-invert span {\r\n          color: #000000 !important;\r\n          -webkit-text-fill-color: #000000 !important;\r\n      }\r\n  }\r\n  [data-ogsc] a.button-invert,\r\n  [data-ogsb] a.button-invert {\r\n      background-color: #FFFFFF !important;\r\n      color: #000000 !important;\r\n      border-color: #FFFFFF !important;\r\n      -webkit-text-fill-color: #000000 !important;\r\n  }\r\n  [data-ogsc] a.button-invert span,\r\n  [data-ogsb] a.button-invert span {\r\n      color: #000000 !important;\r\n      -webkit-text-fill-color: #000000 !important;\r\n  }\r\n  /* Ensure hover keeps text legible even with dark-mode overrides. */\r\n  a.button-invert:hover,\r\n  a.button-invert:focus {\r\n      color: #FFFFFF !important;\r\n      -webkit-text-fill-color: #FFFFFF !important;\r\n  }\r\n  a.button-invert:hover span,\r\n  a.button-invert:focus span {\r\n      color: #FFFFFF !important;\r\n      -webkit-text-fill-color: #FFFFFF !important;\r\n  }\r\n  /* Badges: use real rows so the stacked layout survives across email clients */\r\n  .badges {\r\n      width: 100% !important;\r\n      max-width: 128px !important;\r\n  }\r\n  .badges .badge {\r\n      width: 100% !important;\r\n      vertical-align: bottom !important;\r\n  }\r\n  .badges .badge img {\r\n      width: 120px !important;\r\n      max-width: 120px !important;\r\n      height: auto !important;\r\n      margin: 0 auto !important;\r\n  }\r\n\r\n  /* Desktop: larger typography */\r\n  @media screen and (min-width:480px) {\r\n      h1 {\r\n          font-size: 34px !important;\r\n          line-height: 41px !important;\r\n          letter-spacing: 0.4px;\r\n          font-weight: 400 !important;\r\n      }\r\n      h2 {\r\n        font-size: 18px;\r\n        font-weight: 400;\r\n        margin: 0;\r\n        line-height: 150%;\r\n        letter-spacing: -0.2px;\r\n      }\r\n      /* Header cell: increase side padding on desktop only */\r\n      td.header-td {\r\n          padding-left: 57px !important;\r\n          padding-right: 57px !important;\r\n      }\r\n      /